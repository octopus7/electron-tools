{
  "name": "electron-tools",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Windows-first Electron imaging shell prototype with Photoshop-like document windows.",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:electron:build\" \"npm:dev:renderer\" \"npm:dev:run\"",
    "dev:electron:build": "tsc -p tsconfig.electron.json --watch --preserveWatchOutput",
    "dev:renderer": "vite",
    "dev:run": "wait-on dist-electron/main.js http://127.0.0.1:5173 && cmd /C \"set ELECTRON_RUN_AS_NODE=&& set VITE_DEV_SERVER_URL=http://127.0.0.1:5173&& electron .\"",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "tsc -p tsconfig.app.json --noEmit && vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "start": "cmd /C \"set ELECTRON_RUN_AS_NODE=&& electron .\"",
    "preview": "vite preview"
  },
  "dependencies": {
    "electron": "^35.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "typescript": "^5.8.2",
    "vite": "^6.2.1",
    "wait-on": "^8.0.3"
  }
}
